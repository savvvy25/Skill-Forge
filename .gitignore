# ============================================================
# SkillForge .gitignore
# Full-stack: Spring Boot (Java/Maven) + React (Node.js/Vite)
# ============================================================

# ────────────────────────────────────────────────────────────
# Java / Maven
# ────────────────────────────────────────────────────────────

# Compiled class files
*.class

# Package files
*.jar
*.war
*.ear
*.nar

# Maven build output
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# Maven wrapper (downloaded binary)
.mvn/wrapper/maven-wrapper.jar

# Gradle (in case of future migration)
.gradle/
build/

# ────────────────────────────────────────────────────────────
# Node.js / React / Vite
# ────────────────────────────────────────────────────────────

# Dependencies
node_modules/

# Build output
dist/
dist-ssr/

# Vite cache
.vite/

# npm/yarn/pnpm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
package-lock.json.bak

# ────────────────────────────────────────────────────────────
# Environment Variables
# ────────────────────────────────────────────────────────────

.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# ────────────────────────────────────────────────────────────
# IDE & Editors
# ────────────────────────────────────────────────────────────

# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/

# VS Code
.vscode/
*.code-workspace

# Eclipse
.project
.classpath
.settings/
.factorypath
bin/

# NetBeans
nbproject/
nbbuild/
nbdist/
.nb-gradle/

# STS (Spring Tool Suite)
.springBeans
.sts4-cache/

# ────────────────────────────────────────────────────────────
# Operating System
# ────────────────────────────────────────────────────────────

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
*~
.fuse_hidden*
.Trash-*
.nfs*

# ────────────────────────────────────────────────────────────
# Logs & Temporary Files
# ────────────────────────────────────────────────────────────

*.log
*.tmp
*.temp
*.swp
*.swo
*.bak
*.orig

# Spring Boot logs
spring.log

# ────────────────────────────────────────────────────────────
# Testing & Coverage
# ────────────────────────────────────────────────────────────

# Java test output
surefire-reports/
failsafe-reports/
test-results/

# JavaScript test output
coverage/
*.lcov
.nyc_output/

# ────────────────────────────────────────────────────────────
# Miscellaneous
# ────────────────────────────────────────────────────────────

# Docker
docker-compose.override.yml

# Terraform
*.tfstate
*.tfstate.backup
.terraform/

# Vercel
.vercel/

# Render
.render/

# Thumbnails
*.thumb

# Database files
*.db
*.sqlite
*.sqlite3
