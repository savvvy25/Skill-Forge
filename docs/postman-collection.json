        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Auto-save JWT token to collection variable",
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set(\"authToken\", jsonData.token);",
                  "    console.log(\"✅ Auth token saved to collection variable 'authToken'\");",
                  "    ",
                  "    // Validate response structure",
                  "    pm.test(\"Response has token\", function () {",
                  "        pm.expect(jsonData).to.have.property(\"token\");",
                  "        pm.expect(jsonData.token).to.be.a(\"string\").and.not.empty;",
                  "    });",
                  "    ",
                  "    pm.test(\"Response has user info\", function () {",
                  "        pm.expect(jsonData).to.have.property(\"email\");",
                  "        pm.expect(jsonData).to.have.property(\"name\");",
                  "    });",
                  "    ",
                  "    pm.test(\"Token type is Bearer\", function () {",
                  "        pm.expect(jsonData.type).to.equal(\"Bearer\");",
                  "    });",
                  "} else {",
                  "    console.log(\"❌ Login failed with status: \" + pm.response.code);",
                  "    pm.test(\"Login was successful\", function () {",
                  "        pm.response.to.have.status(200);",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"vishal@example.com\",\n  \"password\": \"SecureP@ss123\"\n}"
            },
            "description": "Authenticate with email and password to receive a JWT token.\n\n**Note:** The test script automatically saves the JWT token to the `authToken` collection variable. All subsequent protected requests will use this token."
