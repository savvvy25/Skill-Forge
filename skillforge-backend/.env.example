# ============================================================
# SkillForge Backend - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit the .env file to version control!
# ============================================================

# --- Database Configuration ---
# JDBC connection string for PostgreSQL
# Local:      jdbc:postgresql://localhost:5432/skillforge
# Neon (prod): jdbc:postgresql://ep-xxxxx.us-east-2.aws.neon.tech/skillforge?sslmode=require
DATABASE_URL=jdbc:postgresql://localhost:5432/skillforge

# Database credentials
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=password

# --- JWT Configuration ---
# Secret key for signing JWT tokens (minimum 256-bit / 32 characters)
# Generate a secure key with: openssl rand -base64 64
JWT_SECRET=your-256-bit-secret-key-here-make-it-long-and-random

# --- CORS Configuration ---
# Comma-separated list of allowed frontend origins
# Local:      http://localhost:5173
# Production: https://skillforge.vercel.app
CORS_ORIGINS=http://localhost:5173
