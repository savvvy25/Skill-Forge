# ============================================================
# SkillForge Backend - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# For LOCAL DEV: No changes needed! The dev profile uses H2
# in-memory database with built-in defaults.
#
# For PRODUCTION (Render): Set these in Render's Environment
# Variables panel — NOT in this file.
#
# NEVER commit the .env file to version control!
# ============================================================

# --- Active Profile ---
# dev  = H2 in-memory database (default, zero config)
# prod = PostgreSQL via Neon (requires DATABASE_* vars)
SPRING_PROFILES_ACTIVE=dev

# --- Database Configuration (required for prod profile) ---
# JDBC connection string for Neon PostgreSQL
# Get these from: Neon Dashboard → Connection Details → Java
DATABASE_URL=jdbc:postgresql://ep-xxxxx.us-east-2.aws.neon.tech/skillforge?sslmode=require
DATABASE_USERNAME=skillforge_owner
DATABASE_PASSWORD=your-neon-password-here

# --- JWT Configuration ---
# Secret key for signing JWT tokens (minimum 256-bit / 32 characters)
# Generate a secure key: openssl rand -base64 64
# A dev default is built-in, but ALWAYS set this in production!
JWT_SECRET=your-256-bit-secret-key-here-make-it-long-and-random

# Token expiration in milliseconds (default: 86400000 = 24 hours)
JWT_EXPIRATION=86400000

# --- CORS Configuration ---
# Comma-separated list of allowed frontend origins
# Local:      http://localhost:5173
# Production: https://skillforge.vercel.app
CORS_ORIGINS=http://localhost:5173

# --- Server Port ---
# Render injects PORT automatically. Locally defaults to 8080.
PORT=8080
