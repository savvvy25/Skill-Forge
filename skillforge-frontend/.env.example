# ============================================================
# SkillForge Frontend - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: All Vite environment variables MUST be prefixed
# with VITE_ to be accessible in the browser at build time.
#
# NEVER commit the .env file to version control!
# ============================================================

# --- API Configuration ---
# Base URL of the SkillForge backend API (no trailing slash)
# Local:      http://localhost:8080
# Production: https://skillforge-backend.onrender.com
VITE_API_URL=http://localhost:8080
